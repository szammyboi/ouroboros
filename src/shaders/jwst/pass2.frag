in vec2 vUV;
out vec4 FragColor;

uniform sampler2D previous;
uniform sampler2D original;
uniform vec2 uResolution;

vec3 pack2vec3(vec3 a, vec3 b) 
{
    uvec3 p = uvec3(packHalf2x16(vec2(a.x,b.x)), packHalf2x16(vec2(a.y,b.y)), packHalf2x16(vec2(a.z,b.z)));
    return vec3(uintBitsToFloat(p.x), uintBitsToFloat(p.y), uintBitsToFloat(p.z));
}

void unpack2vec3(vec3 p, out vec3 a, out vec3 b) 
{
    uvec3 unpacked = uvec3(floatBitsToUint(p.x), floatBitsToUint(p.y), floatBitsToUint(p.z));
    vec2 unpackedA = unpackHalf2x16(unpacked.x);
    vec2 unpackedB = unpackHalf2x16(unpacked.y);
    vec2 unpackedC = unpackHalf2x16(unpacked.z);
    a = vec3(unpackedA.x, unpackedB.x, unpackedC.x);
    b = vec3(unpackedA.y, unpackedB.y, unpackedC.y);
}




void main()
{
   ivec2 resol = ivec2(uResolution.xy/2.0);
   ivec2 coord = ivec2(gl_FragCoord.xy) % resol;
   ivec2 block = ivec2(gl_FragCoord.xy) / resol;

   if (block.x + block.y * 2 >= 1)
      discard;

   vec3 sum = vec3(0.0);
   for (int i = -Nc; i < Nc; i++) 
   {
      //use texelFetch to get the pixel at the current index
      ivec2 pos = ivec2(coord.x, coord.y + i);

      //skip if the coordinate is outside the image
      if(pos.x < 0 || pos.x >= resol.x || pos.y < 0 || pos.y >= resol.y)
         continue;

      //loop over pairs of ranks
      for(int j = 0; j < Nr; j += 2)
      {
         int block_id = j / 2;
         ivec2 block_offset = ivec2(block_id % 2, block_id / 2);
         vec4 pixel = texelFetch(previous, pos + block_offset * resol, 0);

         //unpack the values
         vec3 val1, val2;
         unpack2vec3(pixel.xyz, val1, val2);

         //add the values to the sum
         sum += val1 * V[i + Nc + j * N];
         sum += val2 * V[i + Nc + (j + 1) * N];
      }
   }

   FragColor = vec4(sum, 1.0);
}
