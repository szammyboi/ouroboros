in vec2 vUV;
out vec4 FragColor;

uniform sampler2D previous;
uniform sampler2D original;
uniform sampler2D alt;
uniform vec2 uResolution;

vec3 pack2vec3(vec3 a, vec3 b) 
{
    uvec3 p = uvec3(packHalf2x16(vec2(a.x,b.x)), packHalf2x16(vec2(a.y,b.y)), packHalf2x16(vec2(a.z,b.z)));
    return vec3(uintBitsToFloat(p.x), uintBitsToFloat(p.y), uintBitsToFloat(p.z));
}

void unpack2vec3(vec3 p, out vec3 a, out vec3 b) 
{
    uvec3 unpacked = uvec3(floatBitsToUint(p.x), floatBitsToUint(p.y), floatBitsToUint(p.z));
    vec2 unpackedA = unpackHalf2x16(unpacked.x);
    vec2 unpackedB = unpackHalf2x16(unpacked.y);
    vec2 unpackedC = unpackHalf2x16(unpacked.z);
    a = vec3(unpackedA.x, unpackedB.x, unpackedC.x);
    b = vec3(unpackedA.y, unpackedB.y, unpackedC.y);
}




void main()
{
   ivec2 coord = ivec2(gl_FragCoord.xy) % ivec2(uResolution.xy/2.0);
   ivec2 block = ivec2(gl_FragCoord.xy) / ivec2(uResolution.xy/2.0);
   int rank_offset = 2 * (block.x + block.y * 2);

   if(rank_offset >= Nr)
      discard;

   vec3 sum0 = vec3(0.0);
   vec3 sum1 = vec3(0.0);
   for (int i = -Nc; i < Nc; i++) 
   {
      //use texelFetch to get the pixel at the current index
      //since we are doing it at 1/2 resolution we need to use 1 mip level higher
      vec4 pixel = texelFetch(alt, coord + ivec2(i, 0), 1);
      vec3 pcolor = min(pow(pixel.xyz/(pixel.w+1e-6),vec3(1.3)), 5.0);
      
      //get the rank index
      int offset = i + Nc;
      sum0 += pcolor * U[offset + rank_offset * N];
      sum1 += pcolor * U[offset + (rank_offset + 1) * N];
   }

   //write the sum packed to the output
   FragColor = vec4(pack2vec3(sum0, sum1), 1.0);
   //FragColor = vec4(sum1, 1.0);
   //vec3 col = texture(original, vUV).rgb; 
   //FragColor = vec4(col, 1.0);
}
